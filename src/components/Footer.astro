---
import { navItems, site } from "../siteData.js";
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <img class="footer-logo" src="/images/logo/wooktool-logo-new.webp" alt="WOOKTOOL logo" width="420" height="50" />
      <p>{site.description}</p>
    </div>
    <div>
      <h2>Navigation</h2>
      <ul>
        {navItems.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h2>Contact</h2>
      <p>Email: <a href={`mailto:${site.email}`} data-track="email_click">{site.email}</a></p>
      <p>WhatsApp: <a href={site.whatsappUrl} data-track="whatsapp_click">{site.whatsapp}</a></p>
      <p><a href={site.alibabaUrl} data-track="alibaba_click">Alibaba Store</a></p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2026 WOOKTOOL. Built for Cloudflare Pages static deployment.</p>
  </div>
</footer>
