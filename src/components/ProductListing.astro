---
import CatalogProductCard from "./CatalogProductCard.astro";
const {
  products,
  currentPage,
  eyebrow = "Product catalog",
  title = currentPage ? `Product display page ${currentPage}` : "Product detail entrances",
  description = "Each product window links to a detail page with product photos, specifications, customization options, packaging details, and quality-control notes.",
  showPagination = Boolean(currentPage)
} = Astro.props;
---

<section class="section">
  <div class="section-inner">
    <div class="section-header">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h2>{title}</h2>
      </div>
      <p>{description}</p>
    </div>
    <div class="catalog-grid">
      {products.map((product) => <CatalogProductCard product={product} />)}
    </div>
    {showPagination && (
      <nav class="pagination" aria-label="Product catalog pages">
        <a class={currentPage === 1 ? "is-active" : ""} href="/products/page/1/">Page 1</a>
        <a class={currentPage === 2 ? "is-active" : ""} href="/products/page/2/">Page 2</a>
      </nav>
    )}
  </div>
</section>
