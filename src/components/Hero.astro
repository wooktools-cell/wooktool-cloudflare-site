---
const {
  eyebrow = "China hand tools manufacturer",
  title,
  text,
  primaryLabel = "Request a Quote",
  primaryHref = "/contact/",
  secondaryLabel = "View Products",
  secondaryHref = "/products/",
  desktopImage = "/images/hero/wooktool-hero-desktop.webp",
  mobileImage = "/images/hero/wooktool-hero-mobile.webp",
  imageAlt = "WOOKTOOL hand tools displayed in a factory workshop",
  highlights = [
    "Custom Logo",
    "Custom Color",
    "Custom Specs",
    "Custom Packaging",
    "Quality Control",
    "Fast Delivery",
    "Flexible MOQ",
    "New Product Development",
    "Mold Customization"
  ]
} = Astro.props;
---

<section class="hero">
  <picture class="hero-background" aria-hidden="true">
    <source media="(max-width: 680px)" srcset={mobileImage} />
    <img src={desktopImage} alt={imageAlt} width="1672" height="941" fetchpriority="high" />
  </picture>
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{text}</p>
      <div class="hero-highlights" aria-label="WOOKTOOL manufacturing strengths">
        {highlights.map((item) => <span>{item}</span>)}
      </div>
      <div class="hero-actions">
        <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>
        <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
      </div>
    </div>
  </div>
</section>
