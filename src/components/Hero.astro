---
const {
  eyebrow = "China hand tools manufacturer",
  title,
  text,
  primaryLabel = "Request a Quote",
  primaryHref = "/contact/",
  secondaryLabel = "View Products",
  secondaryHref = "/products/",
  image = "/images/products/custom-tape-measure.png",
  imageAlt = "WOOKTOOL custom tape measure product for importers and private-label buyers"
} = Astro.props;
---

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{text}</p>
    <div class="hero-actions">
      <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>
      <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
    </div>
  </div>
  <div class="hero-product">
    <img src={image} alt={imageAlt} width="760" height="560" />
    <div class="hero-badges" aria-label="WOOKTOOL manufacturing strengths">
      <span>OEM Logo</span>
      <span>Packaging</span>
      <span>Quality Check</span>
    </div>
  </div>
</section>
