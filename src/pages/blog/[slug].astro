---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { site } from "../../siteData.js";
import { breadcrumbSchema } from "../../schema.js";

export async function getStaticPaths() {
  const postModules = import.meta.glob("../../cms/blog/*.md", { eager: true });
  return Object.entries(postModules).map(([path, post]) => {
    const slug = post.frontmatter.slug || path.split("/").pop().replace(/\.md$/, "");
    return {
      params: { slug },
      props: { post }
    };
  });
}

const { post } = Astro.props;
const { Content } = post;
const slug = post.frontmatter.slug || Astro.params.slug;
const path = `/blog/${slug}/`;
const blogSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: post.frontmatter.title,
    description: post.frontmatter.description,
    datePublished: post.frontmatter.date,
    author: {
      "@type": "Organization",
      name: "wooktools"
    },
    publisher: {
      "@type": "Organization",
      name: "wooktools",
      logo: {
        "@type": "ImageObject",
        url: new URL("/images/logo/wooktool-logo-new.webp", site.domain).toString()
      }
    },
    mainEntityOfPage: new URL(path, site.domain).toString()
  },
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog/" },
    { name: post.frontmatter.title, path }
  ])
];
---

<BaseLayout
  title={post.frontmatter.title}
  description={post.frontmatter.description}
  path={path}
  image={post.frontmatter.image}
  schema={blogSchema}
>
  <section class="page-intro">
    <div>
      <p class="eyebrow">{post.frontmatter.date || "Blog"}</p>
      <h1>{post.frontmatter.title}</h1>
      <p>{post.frontmatter.description}</p>
    </div>
  </section>
  <article class="article">
    <Content />
  </article>
  <CTA title="Need help with your sourcing project?" />
</BaseLayout>
