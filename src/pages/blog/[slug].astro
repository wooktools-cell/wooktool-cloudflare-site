---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";

export async function getStaticPaths() {
  const postModules = import.meta.glob("../../cms/blog/*.md", { eager: true });
  return Object.entries(postModules).map(([path, post]) => {
    const slug = post.frontmatter.slug || path.split("/").pop().replace(/\.md$/, "");
    return {
      params: { slug },
      props: { post }
    };
  });
}

const { post } = Astro.props;
const { Content } = post;
const slug = post.frontmatter.slug || Astro.params.slug;
---

<BaseLayout
  title={post.frontmatter.title}
  description={post.frontmatter.description}
  path={`/blog/${slug}/`}
  image={post.frontmatter.image}
>
  <section class="page-intro">
    <div>
      <p class="eyebrow">{post.frontmatter.date || "Blog"}</p>
      <h1>{post.frontmatter.title}</h1>
      <p>{post.frontmatter.description}</p>
    </div>
  </section>
  <article class="article">
    <Content />
  </article>
  <CTA title="Need help with your sourcing project?" />
</BaseLayout>
