---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import factoryGallery from "../cms/factory/gallery.json";
---

<BaseLayout
  title="Hand Tools Factory China | WOOKTOOL Manufacturing Strength"
  description="WOOKTOOL is a hand tools factory in China supporting tape measure, utility knife, screwdriver set, OEM production, supply chain, and lead time control."
  path="/factory/"
>
  <section class="page-intro"><div><p class="eyebrow">Factory</p><h1>Hand Tools Factory China</h1><p>WOOKTOOL provides factory-direct manufacturing support for B2B hand tool buyers who need consistent production, communication, and delivery planning.</p></div></section>
  <section class="section">
    <div class="section-inner grid two">
      <img src="/images/factory/oem-tool-solutions.png" alt="WOOKTOOL hand tools factory and OEM tool solutions image" width="640" height="420" />
      <div>
        <h2>Factory strength for export buyers</h2>
        <ul class="check-list">
          <li>Experienced manufacturing team</li>
          <li>Stable supply chain for components and packaging</li>
          <li>Lead time control based on production schedule</li>
          <li>Export-oriented service for North American market buyers</li>
          <li>Support for importers, wholesalers, distributors, and private-label brands</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section soft">
    <div class="section-inner">
      <div class="section-header">
        <div>
          <p class="eyebrow">Factory gallery</p>
          <h2>Photo positions prepared for real factory proof</h2>
        </div>
        <p>These image blocks are placeholders for future real factory photos. They are designed to show production capability, quality control, packing, and shipment readiness for overseas buyers.</p>
      </div>
      <div class="factory-gallery">
        {factoryGallery.items.map((item) => (
          <article>
            <img src={item.image} alt={item.alt} width="1000" height="720" />
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="section-inner grid four">
      <article class="info-card"><h3>Factory-direct</h3><p>Show buyers that communication and production coordination come from the source.</p></article>
      <article class="info-card"><h3>QC records</h3><p>Reserve space for inspection standards, photos, and buyer-specific quality notes.</p></article>
      <article class="info-card"><h3>Packaging proof</h3><p>Display private-label packaging, carton marks, barcode labels, and retail presentation.</p></article>
      <article class="info-card"><h3>Export support</h3><p>Use this section for shipment preparation, lead time planning, and documentation support.</p></article>
    </div>
  </section>
  <CTA title="Looking for stable hand tool production?" primaryLabel="Send Factory Inquiry" />
</BaseLayout>
