---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import ProductListing from "../components/ProductListing.astro";
import { categoryCatalogs } from "../siteData.js";
---

<BaseLayout
  title="Utility Knife Manufacturer China | OEM Box Cutter Supplier"
  description="WOOKTOOL supplies custom utility knives, box cutters, snap-off knives, safety cutters, and replacement blades with OEM logo, handle color, packaging, QC, and flexible MOQ."
  path="/utility-knives/"
  image="/images/products/catalog/heavy-duty-utility-knife-main.webp"
>
  <section class="page-intro"><div><p class="eyebrow">Utility knives</p><h1>Custom Utility Knife Manufacturer in China</h1><p>WOOKTOOL supplies utility knives, box cutters, snap-off knives, safety cutters, and replacement blades for hardware importers, industrial distributors, retailers, and private-label tool brands.</p></div></section>
  <section class="section">
    <div class="section-inner grid two">
      <img class="product-square-image" src="/images/products/catalog/heavy-duty-utility-knife-main.webp" alt="WOOKTOOL custom utility knife supplier product image" width="1000" height="1000" />
      <div>
        <h2>OEM box cutter and utility knife capability</h2>
        <p>WOOKTOOL supports utility knife manufacturing with custom handle colors, logo placement, blade format, lock style, replacement blade packs, blister cards, hanging cards, color boxes, and carton marks.</p>
        <ul class="check-list">
          <li>Custom utility knife supplier for global importer programs</li>
          <li>Box cutter factory support for retail and industrial channels</li>
          <li>OEM utility knife manufacturer with private-label packaging options</li>
          <li>RFQ review for blade format, handle material, lock design, MOQ, and target market</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section soft">
    <div class="section-inner grid three">
      <article class="info-card"><h3>Blade options</h3><p>Discuss 9 mm, 18 mm, SK5, snap-off, trapezoid, replacement blade pack, safety lock, retractable mechanism, and use scenario.</p></article>
      <article class="info-card"><h3>Branding options</h3><p>Support handle color, logo placement, blister card, hanging card, color box, barcode label, and private-label packaging needs.</p></article>
      <article class="info-card"><h3>Buyer markets</h3><p>Suitable for hardware retail, industrial supply, DIY tool kits, warehouse use, promotional tools, and distributor programs.</p></article>
    </div>
  </section>
  <ProductListing
    products={categoryCatalogs["Utility Knives"]}
    eyebrow="Utility knife products"
    title="5 utility knife product detail entrances"
    description="Reserved product windows for utility knife and box cutter buyers. Each entry opens a detail page for blade format, handle options, safety checks, and packaging."
    showPagination={false}
  />
  <CTA title="Need custom utility knives for your market?" primaryLabel="Send Utility Knife RFQ" />
</BaseLayout>
