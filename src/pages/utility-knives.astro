---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import ProductListing from "../components/ProductListing.astro";
import { categoryCatalogs } from "../siteData.js";
---

<BaseLayout
  title="Utility Knife Manufacturer | Custom Box Cutter Factory China"
  description="WOOKTOOL manufactures utility knives and box cutters with OEM logo, color, blade, handle, and packaging customization for B2B buyers."
  path="/utility-knives/"
>
  <section class="page-intro"><div><p class="eyebrow">Utility knives</p><h1>Utility Knife Manufacturer</h1><p>Source custom utility knives and box cutters for hardware retail, industrial supply, promotional tool kits, and private-label programs.</p></div></section>
  <section class="section">
    <div class="section-inner grid two">
      <img class="product-square-image" src="/images/products/catalog/heavy-duty-utility-knife-main.webp" alt="WOOKTOOL custom utility knife supplier product image" width="1000" height="1000" />
      <div>
        <h2>OEM utility knife capability</h2>
        <p>WOOKTOOL supports utility knife manufacturing with custom handle color, logo, blade type, lock style, replacement blade packs, and retail packaging.</p>
        <ul class="check-list">
          <li>Custom utility knife supplier for importer programs</li>
          <li>Box cutter factory support for retail and industrial channels</li>
          <li>OEM utility knife manufacturer with packaging options</li>
          <li>Product detail review for safety, blade format, and market needs</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section soft">
    <div class="section-inner grid three">
      <article class="info-card"><h3>Blade options</h3><p>Discuss blade size, replacement blade pack, safety lock, retractable mechanism, and use scenario.</p></article>
      <article class="info-card"><h3>Branding options</h3><p>Support handle color, logo placement, blister card, color box, and private-label packaging needs.</p></article>
      <article class="info-card"><h3>Buyer markets</h3><p>Suitable for hardware retail, industrial supply, DIY tool kits, promotional tools, and distributor programs.</p></article>
    </div>
  </section>
  <ProductListing
    products={categoryCatalogs["Utility Knives"]}
    eyebrow="Utility knife products"
    title="5 utility knife product detail entrances"
    description="Reserved product windows for utility knife and box cutter buyers. Each entry opens a detail page for blade format, handle options, safety checks, and packaging."
    showPagination={false}
  />
  <CTA title="Need custom utility knives for your market?" primaryLabel="Send Utility Knife RFQ" />
</BaseLayout>
