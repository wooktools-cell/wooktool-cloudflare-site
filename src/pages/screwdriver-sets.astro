---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import ProductListing from "../components/ProductListing.astro";
import { categoryCatalogs } from "../siteData.js";
---

<BaseLayout
  title="Screwdriver Set Manufacturer | OEM Screwdriver Set Supplier"
  description="WOOKTOOL supplies screwdriver sets with handle, bit, case, packaging, and private-label customization for importers and distributors."
  path="/screwdriver-sets/"
>
  <section class="page-intro"><div><p class="eyebrow">Screwdriver sets</p><h1>Screwdriver Set Manufacturer</h1><p>Develop screwdriver set products with packaging customization for hardware buyers, importer catalogs, retail channels, and private-label brands.</p></div></section>
  <section class="section">
    <div class="section-inner grid two">
      <div>
        <h2>Custom screwdriver set factory support</h2>
        <p>We help buyers define handle style, bit selection, case layout, packaging, labeling, and carton marks for OEM screwdriver set programs.</p>
        <ul class="check-list">
          <li>OEM screwdriver set supplier for B2B buyers</li>
          <li>Custom screwdriver set factory with packaging support</li>
          <li>Bit selection, handle design, and case configuration</li>
          <li>Private-label retail packaging placeholder ready for real artwork</li>
        </ul>
      </div>
      <img class="product-square-image" src="/images/products/screwdriver-set-1000.png" alt="WOOKTOOL OEM screwdriver set supplier product image" width="1000" height="1000" />
    </div>
  </section>
  <ProductListing
    products={categoryCatalogs["Screwdriver Sets"]}
    eyebrow="Screwdriver set products"
    title="5 screwdriver set product detail entrances"
    description="Reserved product windows for screwdriver set buyers. Each entry opens a detail page for set configuration, materials, packaging, and quality-control placeholders."
    showPagination={false}
  />
  <CTA title="Planning a screwdriver set program?" primaryLabel="Request Screwdriver Set Quote" />
</BaseLayout>
