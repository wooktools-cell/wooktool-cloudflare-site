---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../siteData.js";
---

<BaseLayout
  title="RFQ Submitted | WOOKTOOL"
  description="Thank you for sending your WOOKTOOL hand tool RFQ. Our team will review your request and reply by email."
  path="/contact/thank-you/"
>
  <section class="page-intro">
    <div>
      <p class="eyebrow">RFQ submitted</p>
      <h1>Thank you for your inquiry</h1>
      <p>Your RFQ has been sent to the WOOKTOOL sales team. We will review your product interest, quantity, customization needs, packaging, target market, and delivery requirements before replying by email.</p>
      <div class="button-row">
        <a class="button button-primary" href="/products/">View Products</a>
        <a class="button button-secondary" href={site.whatsappUrl}>Contact on WhatsApp</a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="section-inner grid three">
      <article class="info-card">
        <h2>What happens next</h2>
        <p>Our team will check your product details, customization request, packaging needs, and order plan, then reply with practical quotation questions or next-step suggestions.</p>
      </article>
      <article class="info-card">
        <h2>Need faster reply?</h2>
        <p>Send your product photos, logo file, packaging reference, or target price directly by WhatsApp or email so we can review the project more quickly.</p>
      </article>
      <article class="info-card">
        <h2>Continue browsing</h2>
        <ul class="link-list">
          <li><a href="/custom-tape-measure/">Custom tape measure options</a></li>
          <li><a href="/oem-odm/">OEM/ODM hand tools</a></li>
          <li><a href="/factory/">Factory capability</a></li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
