---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { rfqChecklist, site } from "../siteData.js";
import { breadcrumbSchema } from "../schema.js";

const contactSchema = [
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Contact", path: "/contact/" }
  ])
];
---

<BaseLayout
  title="Contact wooktools | Request a Hand Tools RFQ"
  description="Request a WOOKTOOL quote for tape measures, utility knives, screwdriver sets, OEM/ODM hand tools, private-label packaging, wholesale supply, and QC needs."
  path="/contact/"
  schema={contactSchema}
>
  <section class="page-intro"><div><p class="eyebrow">Contact</p><h1>Send Your RFQ to wooktools</h1><p>Send your RFQ details and the wooktools sales team will review product interest, estimated quantity, customization needs, packaging, target market, and delivery requirements.</p></div></section>
  <section class="section">
    <div class="section-inner grid two">
      <div class="contact-panel">
        <h2>Contact information</h2>
        <p><strong>Company:</strong> wooktools</p>
        <p><strong>Brand:</strong> WOOKTOOL</p>
        <p><strong>Website:</strong> {site.domain.replace("https://", "")}</p>
        <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
        <p><strong>WhatsApp:</strong> <a href={site.whatsappUrl}>{site.whatsapp}</a></p>
        <p><strong>Alibaba:</strong> <a href={site.alibabaUrl}>Visit WOOKTOOL Alibaba store</a></p>
        <div class="button-row">
          <a class="button button-primary" href={`mailto:${site.email}`} data-track="email_click">Email Sales Team</a>
          <a class="button button-secondary" href={site.whatsappUrl} data-track="whatsapp_click">WhatsApp</a>
          <a class="button button-secondary" href={site.alibabaUrl} data-track="alibaba_click">Alibaba Store</a>
        </div>
      </div>
      <div class="contact-panel" id="rfq-form">
        <h2>RFQ form</h2>
        <ContactForm />
      </div>
    </div>
  </section>
  <section class="section soft">
    <div class="section-inner">
      <div class="section-header">
        <div>
          <p class="eyebrow">Before sending RFQ</p>
          <h2>Information that helps us quote faster</h2>
        </div>
        <p>Tell us your product type, logo requirement, packaging style, estimated quantity, target market, and delivery schedule. If you already have a reference product, packaging photo, drawing, or target price, include it in your message.</p>
      </div>
      <ul class="feature-list">
        {rfqChecklist.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
