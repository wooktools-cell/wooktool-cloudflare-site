---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found | wooktools"
  description="The page you are looking for could not be found. Continue browsing WOOKTOOL hand tools or contact wooktools for sourcing support."
  path="/404/"
>
  <section class="page-intro">
    <div>
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p>The page may have moved or the link may be incorrect. You can continue browsing WOOKTOOL hand tools or contact the wooktools sales team for sourcing support.</p>
      <div class="button-row">
        <a class="button button-primary" href="/products/">View Products</a>
        <a class="button button-secondary" href="/contact/">Contact wooktools</a>
      </div>
    </div>
  </section>
</BaseLayout>
