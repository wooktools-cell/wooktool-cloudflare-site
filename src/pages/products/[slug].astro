---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import CatalogProductCard from "../../components/CatalogProductCard.astro";
import { catalogProducts, site } from "../../siteData.js";

export function getStaticPaths() {
  return catalogProducts.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const relatedProducts = catalogProducts
  .filter((item) => item.category === product.category && item.slug !== product.slug)
  .slice(0, 3);
const relatedHeadingByCategory = {
  "Tape Measures": "More tape measure options",
  "Utility Knives": "More utility knife options",
  "Screwdriver Sets": "More screwdriver set options"
};
const productUrl = new URL(`/products/${product.slug}/`, site.domain).toString();
const categoryPathByName = {
  "Tape Measures": "/tape-measures/",
  "Utility Knives": "/utility-knives/",
  "Screwdriver Sets": "/screwdriver-sets/"
};
const categoryPath = categoryPathByName[product.category] || "/products/";
const customizationPath =
  product.category === "Tape Measures" ? "/custom-tape-measure/" : "/oem-odm/";
const customizationLabel =
  product.category === "Tape Measures" ? "Customize This Tape Measure" : "Customize This Product";
const productSeoTitle =
  product.metaTitle || `${product.title} Supplier China | OEM WOOKTOOL`;
const productSeoDescription =
  product.metaDescription ||
  `Source ${product.title} from WOOKTOOL with OEM logo, packaging, QC inspection, flexible MOQ, and export support for B2B buyers.`;
const imageUrls = [product.image, ...(product.detailImages || [])].map((image) =>
  new URL(image, site.domain).toString()
);
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.title,
  description: product.summary,
  image: imageUrls,
  url: productUrl,
  brand: {
    "@type": "Brand",
    name: site.name
  },
  manufacturer: {
    "@type": "Organization",
    name: site.name,
    url: site.domain
  },
  category: product.category,
  additionalProperty: Object.entries(product.specs).map(([name, value]) => ({
    "@type": "PropertyValue",
    name,
    value
  }))
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: new URL("/", site.domain).toString()
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Products",
      item: new URL("/products/", site.domain).toString()
    },
    {
      "@type": "ListItem",
      position: 3,
      name: product.category,
      item: new URL(categoryPath, site.domain).toString()
    },
    {
      "@type": "ListItem",
      position: 4,
      name: product.title,
      item: productUrl
    }
  ]
};
---

<BaseLayout
  title={productSeoTitle}
  description={productSeoDescription}
  path={`/products/${product.slug}/`}
  image={product.image}
  type="product"
  schema={[productSchema, breadcrumbSchema]}
>
  <section class="page-intro">
    <div>
      <p class="eyebrow">{product.category}</p>
      <h1>{product.title}</h1>
      <p>{product.summary}</p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner product-detail-layout">
      <img class="product-square-image" src={product.image} alt={`${product.title} main product image on white background`} width="1000" height="1000" />
      <div>
        <p class="eyebrow">Product details</p>
        <h2>Specifications</h2>
        <table class="spec-table">
          <tbody>
            {Object.entries(product.specs).map(([label, value]) => (
              <tr><th>{label}</th><td>{value}</td></tr>
            ))}
          </tbody>
        </table>
        <div class="product-action-row">
          <a class="button button-primary" href="/contact/#rfq-form" data-track="product_detail_rfq_click">Ask for Price</a>
          <a class="button button-secondary" href={customizationPath} data-track="product_detail_custom_click">{customizationLabel}</a>
        </div>
      </div>
    </div>
  </section>

  {product.detailImages?.length > 0 && (
    <section class="section soft">
      <div class="section-inner">
        <div class="section-header">
          <div>
            <p class="eyebrow">Product photos</p>
            <h2>Main details and packaging views</h2>
          </div>
          <p>Each product page keeps one main image and two detail images to balance clear product presentation with fast page loading.</p>
        </div>
        <div class="product-gallery">
          {product.detailImages.map((image, index) => (
            <img src={image} alt={`${product.title} detail view ${index + 1} for OEM buyers`} width="1000" height="1000" loading="lazy" />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-inner grid two">
      <div>
        <p class="eyebrow">Quality control</p>
        <h2>Quality points for this product</h2>
        <p>WOOKTOOL supports material checks, assembly inspection, functional testing, appearance review, and packaging inspection before shipment.</p>
      </div>
      <ul class="check-list">
        {product.quality.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section soft">
    <div class="section-inner grid three">
      <article class="info-card">
        <h3>Key selling points</h3>
        <ul class="mini-list">{product.sellingPoints.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="info-card"><h3>Customization</h3><p>{product.specs.Customization || "Logo, color, packaging, barcode, carton mark, and private-label details can be customized for this product."}</p></article>
      <article class="info-card"><h3>Target buyers</h3><p>{product.targetBuyers}</p></article>
    </div>
  </section>

  {relatedProducts.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <div class="section-header">
          <div>
            <p class="eyebrow">Related products</p>
            <h2>{relatedHeadingByCategory[product.category] || `More ${product.category.toLowerCase()} options`}</h2>
          </div>
          <p>Compare nearby product entries for different specifications, packaging options, and custom branding directions.</p>
        </div>
        <div class="catalog-grid compact">
          {relatedProducts.map((item) => <CatalogProductCard product={item} />)}
        </div>
      </div>
    </section>
  )}

  <CTA
    title={`Request a quote for ${product.title}`}
    text="Send your target quantity, logo, packaging, and delivery requirements. WOOKTOOL will review quotation and customization options for this product."
    primaryLabel="Send Product RFQ"
    primaryHref="/contact/#rfq-form"
    secondaryLabel={customizationLabel}
    secondaryHref={customizationPath}
  />
</BaseLayout>
