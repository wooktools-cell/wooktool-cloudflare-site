---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductListing from "../../../components/ProductListing.astro";
import CTA from "../../../components/CTA.astro";
import { catalogPages } from "../../../siteData.js";

export function getStaticPaths() {
  return catalogPages.map((item) => ({
    params: { page: String(item.page) },
    props: { item }
  }));
}

const { item } = Astro.props;
---

<BaseLayout
  title={`WOOKTOOL Hand Tool Catalog Page ${item.page} | OEM Products`}
  description={`Browse WOOKTOOL catalog page ${item.page} with tape measures, utility knives, screwdriver sets, OEM branding, packaging options, and QC notes.`}
  path={`/products/page/${item.page}/`}
  image={item.products[0]?.image}
>
  <section class="page-intro">
    <div>
      <p class="eyebrow">Catalog page {item.page}</p>
      <h1>WOOKTOOL Product Display Page {item.page}</h1>
      <p>This page is a product framework for future editing. Each product card can be updated with real photos, specifications, quality details, MOQ, packaging, and inquiry notes.</p>
    </div>
  </section>
  <ProductListing products={item.products} currentPage={item.page} />
  <CTA title="Need a quote for one of these products?" primaryLabel="Send Product RFQ" />
</BaseLayout>
