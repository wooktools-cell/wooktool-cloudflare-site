---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout
  title="OEM Hand Tools Manufacturer | WOOKTOOL OEM ODM Service"
  description="WOOKTOOL provides OEM/ODM hand tool services from product design, sampling, packaging, production, quality inspection, and shipment."
  path="/oem-odm/"
>
  <section class="page-intro"><div><p class="eyebrow">OEM/ODM service</p><h1>OEM Hand Tools Manufacturer</h1><p>WOOKTOOL helps B2B buyers turn hand tool ideas, private-label requirements, and packaging concepts into production-ready sourcing programs.</p></div></section>
  <section class="section">
    <div class="section-inner grid three">
      <article class="process-card"><h3>Product design</h3><p>Clarify product type, market, materials, branding, packaging, and target price.</p></article>
      <article class="process-card"><h3>Sampling</h3><p>Prepare sample direction after specifications, logo files, and packaging needs are confirmed.</p></article>
      <article class="process-card"><h3>Packaging</h3><p>Support blister card, color box, display box, barcode label, and carton mark requirements.</p></article>
      <article class="process-card"><h3>Production</h3><p>Plan manufacturing around confirmed order quantity, tooling needs, and delivery window.</p></article>
      <article class="process-card"><h3>Quality check</h3><p>Inspect key product and packaging checkpoints before shipment preparation.</p></article>
      <article class="process-card"><h3>Shipment support</h3><p>Coordinate export-ready information and communication for international buyers.</p></article>
    </div>
  </section>
  <CTA title="Need OEM/ODM support for hand tools?" primaryLabel="Get Custom Solution" />
</BaseLayout>
