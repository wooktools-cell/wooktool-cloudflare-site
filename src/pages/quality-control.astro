---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import { qcSteps } from "../siteData.js";
---

<BaseLayout
  title="Hand Tools Quality Control | WOOKTOOL Inspection Process"
  description="WOOKTOOL hand tools quality control includes raw material inspection, process inspection, finished product inspection, packaging checks, and pre-shipment inspection."
  path="/quality-control/"
>
  <section class="page-intro"><div><p class="eyebrow">Quality control</p><h1>Hand Tools Quality Control</h1><p>Quality control is planned around practical inspection points so buyers can reduce risk before shipment.</p></div></section>
  <section class="section">
    <div class="section-inner grid three">
      {qcSteps.map((step) => (
        <article class="process-card">
          <h3>{step}</h3>
          <p>Inspection detail placeholders can be expanded with your real standards, product tolerances, photos, and test records.</p>
        </article>
      ))}
    </div>
  </section>
  <CTA title="Want inspection details for your RFQ?" primaryLabel="Contact Sales Team" />
</BaseLayout>
